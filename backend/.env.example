# ─────────────────────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# AWS — Credenciais (opcional em dev se usar IAM role / aws configure;
# obrigatório se rodar localmente sem perfil AWS configurado)
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Cognito — OBRIGATÓRIO para autenticação funcionar
# Pode reutilizar o mesmo User Pool da Fase 1, ou criar um novo.
# ─────────────────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Só preencher se o App Client tiver "Client secret" habilitado
COGNITO_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Bedrock — Agente padrão (pode também ser cadastrado via /api/agents)
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# ─────────────────────────────────────────────────────────────────────────────
# DynamoDB — nomes de tabela (prefixo fase2- para não colidir com Fase 1)
# ─────────────────────────────────────────────────────────────────────────────
DYNAMODB_CHATS_TABLE=fase2-chats
DYNAMODB_MESSAGES_TABLE=fase2-messages
DYNAMODB_TABLE_AGENTS=fase2-agents
DYNAMODB_TABLE_PARECERES=fase2-pareceres
DYNAMODB_TABLE_COMPARATIVOS=fase2-comparacoes
DYNAMODB_TABLE_ORGANIZATION=fase2-organization

# ─────────────────────────────────────────────────────────────────────────────
# SISWEB — compliance (opcional em dev; sem isso, logs de interação só geram warning)
# ─────────────────────────────────────────────────────────────────────────────
SISWEB_API_URL=
